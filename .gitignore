# =============================================================================
# .gitignore — pv-report-automation
# =============================================================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# Virtual environment
venv/
.venv/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo

# Credentials (NEVER commit these)
config.py
*.env
.env

# Generated reports (users generate their own)
output/
*.pdf
*.html

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Testing / Coverage
.coverage
htmlcov/
.pytest_cache/

# Docker
.docker/

# Logs
*.log
